[org/gnome/desktop/wm/preferences]
button-layout=':minimize,maximize,close'

[org/gnome/desktop/interface]
color-scheme='prefer-dark'
accent-color='green'

[org/gnome/shell]
enabled-extensions=[
    'matcha-theme@matcha-linux',
    'dash-to-dock@micxgx.gmail.com',
    'emoji-copy@felipeftn',
    'clipboard-indicator@tudmotu.com',
    'caffeine@patapon.info',
    'tilingshell@ferrarodomenico.com'
]

[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/matcha/wallpaper-1.jpg'
picture-uri-dark='file:///usr/share/backgrounds/matcha/wallpaper-1.jpg'
picture-options='zoom'

[org/gnome/shell/extensions/dash-to-dock]
running-indicator-style='DOTS'
show-show-apps-button=false

show-mounts=true
show-mounts-only-mounted=true

custom-background-color=true
background-color='#00280A'

transparency-mode='FIXED'
background-opacity=0.8

dash-max-icon-size=56
dock-position='BOTTOM'

[org/gnome/shell/extensions/tilingshell]
enable-blur-snap-assistant=true
enable-blur-selected-tilepreview=true
top-edge-maximize=true
enable-move-keybindings=false
